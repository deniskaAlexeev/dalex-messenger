# ==============================
# ДАЛЕКС — Конфигурация сервера
# ==============================
# Скопируй этот файл в .env и заполни значения

PORT=3001

# ВАЖНО: замени на случайные строки длиной 32+ символа!
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_min_32_chars
JWT_REFRESH_SECRET=your_refresh_secret_key_change_this_too_min_32_chars

# Для локальной разработки:
CLIENT_URL=http://localhost:5173

# Для Render.com это значение задаётся автоматически через render.yaml
# CLIENT_URL=https://your-app.onrender.com

NODE_ENV=development
# NODE_ENV=production  # раскомментировать для продакшена
